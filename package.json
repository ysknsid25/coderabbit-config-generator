{
    "name": "coderabbit-config-generator",
    "private": true,
    "version": "1.1.0",
    "type": "module",
    "scripts": {
        "predev": "npm run generate:examples",
        "dev": "vite",
        "prebuild": "npm run generate:examples",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "pretypecheck": "npm run generate:examples",
        "typecheck": "tsc -b --noEmit",
        "generate:examples": "tsx scripts/generate-examples.ts",
        "pretest": "npm run generate:examples",
        "test": "vitest run",
        "pretest:coverage": "npm run generate:examples",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "deploy": "npm run build && firebase deploy --only hosting"
    },
    "dependencies": {
        "@formisch/react": "^1.0.0-rc.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "valibot": "^1.4.2",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@stylistic/eslint-plugin": "^5.6.1",
        "@tailwindcss/vite": "^4.3.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^9.16.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^16.5.0",
        "jsdom": "^29.1.1",
        "tailwindcss": "^4.3.2",
        "tsx": "^4.23.1",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.49.0",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
